\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces QLoRA rank sweep on Qwen~2.5~1.5B-Instruct. Retention is reported at the last evaluated generation. Headline ranks ($r=16$ and $r=256$) are evaluated with three seeds; all others with a single seed. Configurations evaluated only to Gen5 correspond to intermediate dose-response points.}}{7}{table.2}\protected@file@percent }
\newlabel{tab:rank_sweep}{{2}{7}{QLoRA rank sweep on Qwen~2.5~1.5B-Instruct. Retention is reported at the last evaluated generation. Headline ranks ($r=16$ and $r=256$) are evaluated with three seeds; all others with a single seed. Configurations evaluated only to Gen5 correspond to intermediate dose-response points}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces K0 retention trajectories over 10 recursive generations for three representative ranks on Qwen~2.5~1.5B. Thin lines show individual seeds; bold lines show the mean. The $r=16$ and $r=256$ conditions are each evaluated with three seeds (15, 137, 256); $r=128$ is evaluated with a single seed.}}{8}{figure.1}\protected@file@percent }
\newlabel{fig:trajectories}{{1}{8}{K0 retention trajectories over 10 recursive generations for three representative ranks on Qwen~2.5~1.5B. Thin lines show individual seeds; bold lines show the mean. The $r=16$ and $r=256$ conditions are each evaluated with three seeds (15, 137, 256); $r=128$ is evaluated with a single seed}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Dose-response relationship between nominal adapter rank and recursive stability on Qwen~2.5~1.5B. Left panel: Gen10 K0 retention (\%) versus nominal rank. Right panel: mean effective rank versus nominal rank. Retention declines monotonically with increasing effective update capacity; the sharpest drop occurs between $r=128$ (bounded, 88.6\%) and $r=256$ (degradative, 78.0\%).}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:dose_response}{{2}{8}{Dose-response relationship between nominal adapter rank and recursive stability on Qwen~2.5~1.5B. Left panel: Gen10 K0 retention (\%) versus nominal rank. Right panel: mean effective rank versus nominal rank. Retention declines monotonically with increasing effective update capacity; the sharpest drop occurs between $r=128$ (bounded, 88.6\%) and $r=256$ (degradative, 78.0\%)}{figure.2}{}}

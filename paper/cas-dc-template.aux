\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces QLoRA rank sweep on Gemma~3~1B~IT. Boundary ranks ($r=4$ and $r=16$) are evaluated with three seeds; $r=2$ and $r=256$ are evaluated with a single seed. Retention is reported at Gen5 for comparability across ranks; the $r=4$ condition was additionally extended to Gen10 (seed~15: 93.6\%).}}{9}{table.3}\protected@file@percent }
\newlabel{tab:gemma3}{{3}{9}{QLoRA rank sweep on Gemma~3~1B~IT. Boundary ranks ($r=4$ and $r=16$) are evaluated with three seeds; $r=2$ and $r=256$ are evaluated with a single seed. Retention is reported at Gen5 for comparability across ranks; the $r=4$ condition was additionally extended to Gen10 (seed~15: 93.6\%)}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces K0 retention versus mean effective rank across three backbones. Marker shapes distinguish backbones (circle: Qwen, square: Gemma~3, triangle: Gemma~4); colors indicate regime membership (blue: homeostatic, orange: transition zone, red: degradative). The regime transition occurs at substantially different effective-rank values across architectures.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:cross_backbone}{{3}{10}{K0 retention versus mean effective rank across three backbones. Marker shapes distinguish backbones (circle: Qwen, square: Gemma~3, triangle: Gemma~4); colors indicate regime membership (blue: homeostatic, orange: transition zone, red: degradative). The regime transition occurs at substantially different effective-rank values across architectures}{figure.3}{}}
